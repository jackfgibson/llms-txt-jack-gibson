# Copy to .env.local and fill in. Never commit real secrets.

# Neon Postgres connection strings (https://console.neon.tech → Connect)
# Pooled (PgBouncer) — app runtime via @neondatabase/serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
# Direct (non-pooled) — drizzle-kit migrations
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# LLM providers — at least one enables grounded descriptions (mode="llm").
# Auto-select order when no provider is specified: Anthropic → OpenAI → Gemini.
# App fully works without any key (descriptions fall back to meta/first sentence, mode="fallback").
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Inngest. For local dev set INNGEST_DEV=1 (no keys needed; pairs with `npx inngest-cli dev`).
# In production leave INNGEST_DEV unset and provide the keys from https://app.inngest.com → Manage → Keys.
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
